# Copy this file to .env and fill in your actual keys
# NEVER commit .env to GitHub

# Zerodha Kite Connect (₹500/month — kite.trade)
KITE_API_KEY=your_kite_api_key_here
KITE_API_SECRET=your_kite_api_secret_here
KITE_ACCESS_TOKEN=generated_each_day_via_login

# News API (free tier — newsapi.org)
NEWS_API_KEY=your_newsapi_key_here

# Gemini API — cloud fallback when Ollama offline (free tier)
# Get from: aistudio.google.com
GEMINI_API_KEY_1=your_account_a_key_here
GEMINI_API_KEY_2=your_account_b_key_here
GEMINI_API_KEY_3=your_account_c_key_here
GEMINI_API_KEY_4=your_account_d_key_here
GEMINI_API_KEY_5=your_account_e_key_here
GEMINI_API_KEY_6=your_account_f_key_here
GEMINI_API_KEY_7=your_account_g_key_here
GEMINI_USE_PRO=false

# Scheduler
SCHEDULER_ENABLED=true

# Database
DB_MODE=sqlite                    # sqlite or postgres
DB_PATH=ritam.db                  # SQLite only
DATABASE_URL=                     # PostgreSQL only (postgres://...)
TIMESCALE_URL=postgresql://user:pass@host:5432/ritam

# Deployment
ENVIRONMENT=development           # development or production
SENTRY_DSN=                       # Optional — Sentry error tracking

# Environment
ENV=development
LOG_LEVEL=INFO
